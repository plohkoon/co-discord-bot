<div class="mb-6">
  <% if @back_href %>
    <%= link_to "← #{@back_label}", @back_href, class: "text-sm text-muted-foreground hover:text-foreground" %>
  <% end %>
  <div class="flex items-end justify-between gap-4 mt-1">
    <div class="min-w-0">
      <h1 class="text-2xl font-semibold text-foreground truncate"><%= @title %></h1>
      <% if @subtitle %><p class="text-sm text-muted-foreground mt-0.5"><%= @subtitle %></p><% end %>
    </div>
    <% if actions? %><div class="shrink-0"><%= actions %></div><% end %>
  </div>
</div>
