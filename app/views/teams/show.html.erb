<% content_for :title, "#{@team.name} · co-bot" %>

<%= link_to "← #{@guild.name}", guild_path(@guild), class: "text-sm text-slate-500 hover:text-slate-300" %>
<h1 class="text-xl font-semibold text-slate-100 mt-1 mb-6"><%= @team.name %></h1>

<div class="grid lg:grid-cols-2 gap-8">
  <section>
    <h2 class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-3">
      Application questions <span class="text-slate-600">(<%= @questions.size %>/<%= ApplicationQuestion::MAX_PER_TEAM %>)</span>
    </h2>

    <div class="space-y-3">
      <% @questions.each do |question| %>
        <%= render "team_questions/form", guild: @guild, team: @team, question: question %>
      <% end %>
    </div>

    <% if @questions.size < ApplicationQuestion::MAX_PER_TEAM %>
      <div class="mt-4">
        <h3 class="text-xs text-slate-500 mb-2">Add a question</h3>
        <%= render "team_questions/form", guild: @guild, team: @team, question: @new_question %>
      </div>
    <% else %>
      <p class="mt-3 text-xs text-slate-500">Discord modals allow at most <%= ApplicationQuestion::MAX_PER_TEAM %> questions.</p>
    <% end %>
  </section>

  <section>
    <h2 class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-3">Recent applications</h2>
    <% if @applications.empty? %>
      <p class="text-slate-500 text-sm">No applications yet.</p>
    <% else %>
      <div class="space-y-2">
        <% @applications.each do |application| %>
          <%= link_to guild_application_path(@guild, application),
                class: "flex items-center justify-between rounded-lg border border-slate-800 bg-slate-900/40 hover:bg-slate-900 px-4 py-2.5 transition" do %>
            <span class="text-sm text-slate-200"><%= application.discord_username.presence || application.discord_user_id %></span>
            <%= render "team_applications/status_badge", status: application.status %>
          <% end %>
        <% end %>
      </div>
    <% end %>
  </section>
</div>
