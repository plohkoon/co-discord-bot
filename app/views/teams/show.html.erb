<% content_for :title, "#{@team.name} · co-bot" %>

<%= render Ui::PageHeaderComponent.new(title: @team.name, back_href: guild_path(@guild), back_label: @guild.name) %>

<div class="grid grid-cols-3 gap-3 mb-10">
  <%= render Ui::StatTileComponent.new(value: @counts["active"], label: "Active") %>
  <%= render Ui::StatTileComponent.new(value: @counts["pending"], label: "Pending", accent: @counts["pending"].to_i.positive?) %>
  <%= render Ui::StatTileComponent.new(value: @counts["archived"], label: "Archived") %>
</div>

<% if can_manage? || officer_of?(@team) %>
<%= render Ui::SectionComponent.new(title: "Team details", classes: "mb-12") do %>
  <p class="text-xs text-muted-foreground -mt-1 mb-4">
    Shown in the server's team directory (<code class="text-muted-foreground bg-secondary px-1 py-0.5 rounded">/team roster</code>).
    Categories and team types come from this server's lists (edited on the server page).
    Team leads are read live from the officer role, so they aren't edited here.
  </p>
  <%= form_with model: @team, url: guild_team_path(@guild, @team), method: :patch, scope: :team,
        class: "rounded-lg border border-border bg-card p-4 space-y-3" do |f| %>
    <div class="grid gap-3 sm:grid-cols-2">
      <label class="block sm:col-span-2">
        <span class="text-xs text-muted-foreground">Team name</span>
        <%= f.text_field :name, required: true, maxlength: 100, class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Category (directory header)</span>
        <%= f.select :team_category_id, options_for_select(@team_categories.map { |c| [ c.name, c.id ] }, @team.team_category_id),
              { include_blank: "No category" }, class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Team type</span>
        <%= f.select :team_type_id, options_for_select(@team_types.map { |t| [ t.name, t.id ] }, @team.team_type_id),
              { include_blank: "No type" }, class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Emote (shown before the team name)</span>
        <%= f.text_field :emote, placeholder: "e.g. ⚔️ or :emote_name:", class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Progression</span>
        <%= f.text_field :progression, placeholder: "e.g. Currently 7/9 H", class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Requirements</span>
        <%= f.text_field :requirements, placeholder: "e.g. Req. iLvl - 250+", class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Date and time</span>
        <%= f.text_field :date_and_time, placeholder: "e.g. Tuesdays 7-10pm CT", class: "field w-full mt-1" %>
      </label>
      <label class="block">
        <span class="text-xs text-muted-foreground">Current needs</span>
        <%= f.text_field :current_needs, placeholder: "e.g. DPS (esp. Warlock)", class: "field w-full mt-1" %>
      </label>
      <% if can_manage? %>
        <label class="block">
          <span class="text-xs text-muted-foreground">Position (sort order in the roster, lower first)</span>
          <%= f.number_field :position, class: "field w-full mt-1" %>
        </label>
      <% end %>
    </div>
    <div class="flex justify-end">
      <%= f.submit "Save roster details", class: Ui::ButtonComponent.classes(variant: :gold) %>
    </div>
  <% end %>
<% end %>
<% end %>

<%= render Ui::SectionComponent.new(title: "Members", classes: "mb-12") do %>
  <% ordered = @members_by_status.values_at("pending", "active", "archived").compact.flatten %>
  <% if ordered.empty? %>
    <%= render Ui::EmptyStateComponent.new do %>
      No members yet. They'll appear here when people apply or receive the team role.
    <% end %>
  <% else %>
    <div class="rounded-xl border border-border bg-card divide-y divide-border overflow-hidden">
      <% ordered.each do |member| %>
        <%= link_to guild_team_membership_path(@guild, @team, member),
              class: "flex items-center gap-3 px-4 py-3 hover:bg-secondary/40 transition" do %>
          <%= render Ui::AvatarComponent.new(name: member.discord_username) %>
          <div class="flex-1 min-w-0">
            <div class="text-sm text-foreground truncate"><%= member.discord_username.presence || member.discord_user_id %></div>
            <div class="text-xs text-muted-foreground">
              <%= pluralize(@app_counts[member.id].to_i, "application") %> · updated <%= time_ago_in_words(member.updated_at) %> ago
            </div>
          </div>
          <%= render StatusBadgeComponent.new(status: member.status) %>
        <% end %>
      <% end %>
    </div>
  <% end %>
<% end %>

<% if can_manage? || officer_of?(@team) %>
<%= render Ui::SectionComponent.new(title: "Application questions", meta: "(#{@questions.size}/#{ApplicationQuestion::MAX_PER_TEAM})") do %>
  <p class="text-xs text-muted-foreground -mt-1 mb-4">Shown to applicants in the <code class="text-muted-foreground bg-secondary px-1 py-0.5 rounded">/apply</code> modal.</p>

  <div class="space-y-3">
    <% @questions.each do |question| %>
      <%= render "team_questions/form", guild: @guild, team: @team, question: question %>
    <% end %>
  </div>

  <% if @questions.size < ApplicationQuestion::MAX_PER_TEAM %>
    <div class="mt-5">
      <h3 class="text-xs text-muted-foreground mb-2">Add a question</h3>
      <%= render "team_questions/form", guild: @guild, team: @team, question: @new_question %>
    </div>
  <% else %>
    <p class="mt-3 text-xs text-muted-foreground">Discord modals allow at most <%= ApplicationQuestion::MAX_PER_TEAM %> questions.</p>
  <% end %>
<% end %>
<% end %>
