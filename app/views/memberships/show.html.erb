<% content_for :title, "#{@membership.discord_username.presence || @membership.discord_user_id} · #{@team.name}" %>

<%= link_to "← #{@team.name}", guild_team_path(@guild, @team), class: "text-sm text-muted-foreground hover:text-foreground" %>

<div class="flex items-center gap-3 mt-2 mb-1">
  <%= render Ui::AvatarComponent.new(name: @membership.discord_username, size: :lg) %>
  <div class="min-w-0">
    <h1 class="text-xl font-semibold text-foreground truncate">
      <%= @membership.discord_username.presence || @membership.discord_user_id %>
    </h1>
    <div class="text-xs text-muted-foreground"><%= @team.name %></div>
  </div>
  <div class="ml-auto shrink-0"><%= render StatusBadgeComponent.new(status: @membership.status) %></div>
</div>
<p class="text-xs text-muted-foreground mb-8">
  <% if @membership.joined_at %>Joined <%= @membership.joined_at.strftime("%b %-d, %Y") %><% end %>
  <% if @membership.left_at %> · left <%= @membership.left_at.strftime("%b %-d, %Y") %><% end %>
</p>

<div class="grid lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2">
    <%= render Ui::SectionComponent.new(title: "Application history") do %>
      <% if @applications.empty? %>
        <p class="text-muted-foreground text-sm">No applications on record.</p>
      <% else %>
        <div class="space-y-4">
          <% @applications.each do |application| %>
            <%= render Ui::CardComponent.new do %>
              <div class="flex items-center justify-between mb-3">
                <div class="text-xs text-muted-foreground">
                  <%= application.created_at.strftime("%b %-d, %Y at %H:%M") %><% if application.manual? %> · manual role grant<% end %>
                </div>
                <%= render StatusBadgeComponent.new(status: application.status) %>
              </div>
              <% if application.application_answers.any? %>
                <div class="space-y-3">
                  <% application.application_answers.each do |answer| %>
                    <div>
                      <div class="text-xs text-muted-foreground mb-0.5"><%= answer.question_label %></div>
                      <div class="text-sm text-foreground whitespace-pre-wrap"><%= answer.answer.presence || "—" %></div>
                    </div>
                  <% end %>
                </div>
              <% else %>
                <p class="text-xs text-muted-foreground">No answers — the role was granted manually.</p>
              <% end %>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>

  <aside>
    <%= render Ui::SectionComponent.new(title: "Notes", meta: "· officers only") do %>
      <%= render Ui::CardComponent.new do %>
        <div class="space-y-3 mb-3">
          <% @notes.each do |note| %>
            <div class="text-sm">
              <div class="text-foreground whitespace-pre-wrap"><%= note.body %></div>
              <div class="text-xs text-muted-foreground mt-0.5 flex items-center justify-between gap-2">
                <span class="truncate"><%= note.author_username.presence || note.author_discord_id %> · <%= note.created_at.strftime("%b %-d") %></span>
                <%= button_to "×", guild_team_membership_note_path(@guild, @team, @membership, note), method: :delete,
                      class: "text-muted-foreground hover:text-light-red leading-none shrink-0",
                      form: { data: { turbo_confirm: "Delete note?" } } %>
              </div>
            </div>
          <% end %>
          <% if @notes.empty? %><p class="text-xs text-muted-foreground">No notes yet.</p><% end %>
        </div>
        <%= form_with url: guild_team_membership_notes_path(@guild, @team, @membership), scope: :membership_note do |f| %>
          <%= f.text_area :body, rows: 2, placeholder: "Add a note…", class: "field" %>
          <div class="text-right mt-1">
            <%= f.submit "Add note", class: Ui::ButtonComponent.classes(variant: :gold, size: :sm) %>
          </div>
        <% end %>
      <% end %>
    <% end %>
  </aside>
</div>
