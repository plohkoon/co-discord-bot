<!DOCTYPE html>
<html class="h-full">
  <head>
    <title><%= content_for(:title) || "co-bot" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-full">
    <header class="sticky top-0 z-50 border-b border-border bg-card/70 backdrop-blur">
      <div class="mx-auto max-w-5xl px-5 h-14 flex items-center justify-between">
        <%= link_to "co-bot", root_path, class: "font-semibold tracking-tight text-gold" %>
        <% if logged_in? %>
          <div class="flex items-center gap-3 text-sm">
            <% if current_user.admin? %>
              <%= link_to "Admin", admin_root_path, class: "text-muted-foreground hover:text-foreground transition" %>
            <% end %>
            <% if current_user.avatar_url %>
              <%= image_tag current_user.avatar_url, alt: "", class: "w-7 h-7 rounded-full" %>
            <% else %>
              <%= render Ui::AvatarComponent.new(name: current_user.display_name) %>
            <% end %>
            <span class="text-muted-foreground"><%= current_user.display_name %></span>
            <%= button_to "Sign out", logout_path, method: :delete,
                  class: "text-muted-foreground hover:text-foreground transition" %>
          </div>
        <% end %>
      </div>
    </header>

    <% if flash.any? %>
      <div class="mx-auto max-w-5xl px-5 mt-4 space-y-2">
        <% flash.each do |type, message| %>
          <div class="rounded-lg px-4 py-2 text-sm border <%= type.to_s == "alert" ? "bg-light-red/10 text-light-red border-light-red/30" : "bg-emerald-500/10 text-emerald-300 border-emerald-500/30" %>">
            <%= message %>
          </div>
        <% end %>
      </div>
    <% end %>

    <main class="mx-auto max-w-5xl px-5 py-8">
      <%= yield %>
    </main>
  </body>
</html>
