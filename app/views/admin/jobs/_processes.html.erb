<% if @processes.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>
    No Solid Queue processes are running — jobs won't execute until a worker starts
    (bin/jobs in dev, SOLID_QUEUE_IN_PUMA in production).
  <% end %>
<% else %>
  <div class="overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-muted-foreground">
          <th class="px-3 py-2 font-medium">Kind</th>
          <th class="px-3 py-2 font-medium">Name</th>
          <th class="px-3 py-2 font-medium">PID</th>
          <th class="px-3 py-2 font-medium">Host</th>
          <th class="px-3 py-2 font-medium">Heartbeat</th>
          <th class="px-3 py-2 font-medium">Started</th>
        </tr>
      </thead>
      <tbody>
        <% @processes.each do |process| %>
          <tr class="border-b border-border/50 last:border-0 hover:bg-secondary/40">
            <td class="px-3 py-2 font-medium text-foreground"><%= process.kind %></td>
            <td class="px-3 py-2 text-muted-foreground"><%= process.name %></td>
            <td class="px-3 py-2 text-muted-foreground"><%= process.pid %></td>
            <td class="px-3 py-2 text-muted-foreground"><%= process.hostname %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(process.last_heartbeat_at) %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(process.created_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
