<% if @jobs.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>No jobs yet.<% end %>
<% else %>
  <div class="overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-muted-foreground">
          <th class="px-3 py-2 font-medium">ID</th>
          <th class="px-3 py-2 font-medium">Job</th>
          <th class="px-3 py-2 font-medium">Queue</th>
          <th class="px-3 py-2 font-medium">Status</th>
          <th class="px-3 py-2 font-medium">Created</th>
          <th class="px-3 py-2 font-medium">Finished</th>
        </tr>
      </thead>
      <tbody>
        <% @jobs.each do |job| %>
          <tr class="border-b border-border/50 last:border-0 hover:bg-secondary/40">
            <td class="px-3 py-2 text-muted-foreground"><%= job.id %></td>
            <td class="px-3 py-2">
              <div class="font-medium text-foreground"><%= job.class_name %></div>
              <% if job.arguments.present? %>
                <div class="max-w-md truncate text-xs text-muted-foreground"><%= job.arguments.to_s.truncate(120) %></div>
              <% end %>
            </td>
            <td class="px-3 py-2 text-muted-foreground"><%= job.queue_name %></td>
            <td class="px-3 py-2"><%= admin_job_status_badge(job_status(job)) %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(job.created_at) %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(job.finished_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "admin/pagination", meta: @meta %>
