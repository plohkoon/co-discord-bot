<% if @scheduled.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>Nothing scheduled.<% end %>
<% else %>
  <div class="overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-muted-foreground">
          <th class="px-3 py-2 font-medium">Job</th>
          <th class="px-3 py-2 font-medium">Queue</th>
          <th class="px-3 py-2 font-medium">Runs</th>
        </tr>
      </thead>
      <tbody>
        <% @scheduled.each do |scheduled| %>
          <tr class="border-b border-border/50 last:border-0 hover:bg-secondary/40">
            <td class="px-3 py-2">
              <div class="font-medium text-foreground"><%= scheduled.job&.class_name %></div>
              <% if scheduled.job&.arguments.present? %>
                <div class="max-w-md truncate text-xs text-muted-foreground"><%= scheduled.job.arguments.to_s.truncate(120) %></div>
              <% end %>
            </td>
            <td class="px-3 py-2 text-muted-foreground"><%= scheduled.queue_name %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(scheduled.scheduled_at) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "admin/pagination", meta: @meta %>
