<% if @tasks.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>No recurring tasks registered (they load from config/recurring.yml).<% end %>
<% else %>
  <div class="overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-muted-foreground">
          <th class="px-3 py-2 font-medium">Key</th>
          <th class="px-3 py-2 font-medium">Schedule</th>
          <th class="px-3 py-2 font-medium">Runs</th>
          <th class="px-3 py-2 font-medium">Queue</th>
          <th class="px-3 py-2 font-medium">Last run</th>
        </tr>
      </thead>
      <tbody>
        <% @tasks.each do |task, last_run| %>
          <tr class="border-b border-border/50 last:border-0 hover:bg-secondary/40">
            <td class="px-3 py-2 font-medium text-foreground"><%= task.key %></td>
            <td class="px-3 py-2 text-muted-foreground"><%= task.schedule %></td>
            <td class="px-3 py-2 text-muted-foreground">
              <%= task.class_name.presence || task.command&.truncate(80) %>
            </td>
            <td class="px-3 py-2 text-muted-foreground"><%= task.queue_name %></td>
            <td class="px-3 py-2 whitespace-nowrap text-muted-foreground"><%= admin_time(last_run) %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
