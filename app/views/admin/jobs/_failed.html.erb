<% if @failed.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>No failed jobs. 🎉<% end %>
<% else %>
  <div class="mb-3 flex justify-end gap-2">
    <%= button_to "Retry all", admin_jobs_retry_all_path,
          class: Ui::ButtonComponent.classes(variant: :outline, size: :sm) %>
    <%= button_to "Discard all", admin_jobs_discard_all_path,
          form: { data: { turbo_confirm: "Discard ALL failed jobs? This cannot be undone." } },
          class: Ui::ButtonComponent.classes(variant: :danger, size: :sm) %>
  </div>

  <div class="overflow-x-auto rounded-xl border border-border bg-card">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-left text-xs uppercase tracking-wide text-muted-foreground">
          <th class="px-3 py-2 font-medium">Job</th>
          <th class="px-3 py-2 font-medium">Error</th>
          <th class="px-3 py-2 font-medium">Failed</th>
          <th class="px-3 py-2 font-medium"></th>
        </tr>
      </thead>
      <tbody>
        <% @failed.each do |failed| %>
          <tr class="border-b border-border/50 last:border-0 hover:bg-secondary/40">
            <td class="px-3 py-2 align-top">
              <div class="font-medium text-foreground"><%= failed.job&.class_name %></div>
              <div class="text-xs text-muted-foreground"><%= failed.job&.queue_name %></div>
            </td>
            <td class="px-3 py-2 align-top">
              <div class="font-medium text-light-red"><%= failed.exception_class %></div>
              <div class="max-w-lg text-xs text-muted-foreground"><%= failed.message&.truncate(300) %></div>
            </td>
            <td class="px-3 py-2 align-top whitespace-nowrap text-muted-foreground"><%= admin_time(failed.created_at) %></td>
            <td class="px-3 py-2 align-top">
              <div class="flex justify-end gap-2">
                <%= button_to "Retry", admin_job_retry_path(failed.id),
                      class: Ui::ButtonComponent.classes(variant: :outline, size: :sm) %>
                <%= button_to "Discard", admin_job_discard_path(failed.id),
                      form: { data: { turbo_confirm: "Discard this job?" } },
                      class: Ui::ButtonComponent.classes(variant: :danger, size: :sm) %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

<%= render "admin/pagination", meta: @meta %>
