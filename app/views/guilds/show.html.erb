<% content_for :title, "#{@guild.name} · co-bot" %>

<div class="flex items-start justify-between mb-6">
  <div>
    <%= link_to "← Servers", root_path, class: "text-sm text-slate-500 hover:text-slate-300" %>
    <h1 class="text-xl font-semibold text-slate-100 mt-1"><%= @guild.name %></h1>
  </div>
  <%= link_to "All applications", guild_applications_path(@guild),
        class: "text-sm rounded-lg border border-slate-700 px-3 py-1.5 hover:bg-slate-800 transition" %>
</div>

<h2 class="text-xs font-medium text-slate-400 uppercase tracking-wide mb-3">Teams</h2>

<% if @teams.empty? %>
  <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-8 text-center text-slate-400">
    No teams yet. Create one in Discord with <code class="text-slate-200 bg-slate-800 px-1.5 py-0.5 rounded">/team create</code>.
  </div>
<% else %>
  <div class="space-y-2">
    <% @teams.each do |team| %>
      <%= link_to guild_team_path(@guild, team),
            class: "flex items-center justify-between rounded-xl border border-slate-800 bg-slate-900/40 hover:bg-slate-900 px-4 py-3 transition" do %>
        <div>
          <div class="font-medium text-slate-100"><%= team.name %></div>
          <div class="text-xs text-slate-500">
            <%= pluralize(team.application_questions.count, "question") %> ·
            <%= team.team_applications.pending.count %> pending
          </div>
        </div>
        <span class="text-slate-500">→</span>
      <% end %>
    <% end %>
  </div>
<% end %>
