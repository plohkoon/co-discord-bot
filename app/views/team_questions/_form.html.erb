<%# question is either persisted (edit) or a new record (add). %>
<div class="rounded-lg border border-slate-800 bg-slate-900/40 p-3">
  <%= form_with model: question,
        url: (question.persisted? ? guild_team_question_path(guild, team, question) : guild_team_questions_path(guild, team)),
        method: (question.persisted? ? :patch : :post),
        scope: :application_question do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :label, placeholder: "Question (max 45 chars)", maxlength: 45,
            class: "flex-1 rounded-md bg-slate-800 border border-slate-700 px-3 py-1.5 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#5865F2]" %>
      <%= f.select :style, [ [ "Short", "short" ], [ "Paragraph", "paragraph" ] ], {},
            class: "rounded-md bg-slate-800 border border-slate-700 px-2 py-1.5 text-sm text-slate-200" %>
    </div>
    <div class="flex items-center gap-3 mt-2">
      <%= f.text_field :placeholder, placeholder: "Placeholder hint (optional)", maxlength: 100,
            class: "flex-1 rounded-md bg-slate-800 border border-slate-700 px-3 py-1.5 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#5865F2]" %>
      <label class="flex items-center gap-1.5 text-sm text-slate-400 shrink-0">
        <%= f.check_box :required, class: "rounded bg-slate-800 border-slate-600 text-[#5865F2]" %> Required
      </label>
      <%= f.submit (question.persisted? ? "Save" : "Add"),
            class: "text-xs rounded-md bg-[#5865F2] hover:bg-[#4752c4] px-3 py-1.5 font-medium text-white cursor-pointer" %>
    </div>
  <% end %>

  <% if question.persisted? %>
    <div class="mt-1.5 text-right">
      <%= button_to "Delete", guild_team_question_path(guild, team, question), method: :delete,
            class: "text-xs text-red-400/80 hover:text-red-300",
            form: { data: { turbo_confirm: "Delete this question?" } } %>
    </div>
  <% end %>
</div>
