<%# question is either persisted (edit) or a new record (add). %>
<div class="rounded-lg border border-border bg-card p-3">
  <%= form_with model: question,
        url: (question.persisted? ? guild_team_question_path(guild, team, question) : guild_team_questions_path(guild, team)),
        method: (question.persisted? ? :patch : :post),
        scope: :application_question, class: "space-y-2" do |f| %>
    <div class="flex items-center gap-2">
      <%= f.text_field :label, placeholder: "Question (max 45 chars)", maxlength: 45, class: "field flex-1 min-w-0" %>
      <%= f.select :style, [ [ "Short", "short" ], [ "Paragraph", "paragraph" ] ], {}, class: "field w-auto shrink-0" %>
      <label class="flex items-center gap-1.5 text-sm text-muted-foreground shrink-0 px-1">
        <%= f.check_box :required, class: "field-checkbox" %> Required
      </label>
    </div>
    <div class="flex items-center gap-2">
      <%= f.text_field :placeholder, placeholder: "Placeholder hint (optional)", maxlength: 100, class: "field flex-1 min-w-0" %>
      <%= f.submit (question.persisted? ? "Save" : "Add"), class: "#{Ui::ButtonComponent.classes(variant: :gold)} shrink-0" %>
    </div>
  <% end %>

  <% if question.persisted? %>
    <div class="mt-1.5 text-right">
      <%= button_to "Delete question", guild_team_question_path(guild, team, question), method: :delete,
            class: Ui::ButtonComponent.classes(variant: :danger, size: :sm),
            form: { data: { turbo_confirm: "Delete this question?" } } %>
    </div>
  <% end %>
</div>
