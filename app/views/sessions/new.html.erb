<% content_for :title, "Sign in · co-bot" %>

<div class="max-w-md mx-auto text-center py-20">
  <h1 class="text-3xl font-semibold text-gold tracking-tight">co-bot</h1>
  <p class="mt-2 text-muted-foreground">Manage your Discord teams and review applications.</p>

  <div class="mt-8">
    <%# data-turbo=false: full-page POST so the browser can follow OmniAuth's redirect to discord.com. %>
    <%= button_to "/auth/discord", method: :post, form: { data: { turbo: false } },
          class: Ui::ButtonComponent.classes(variant: :gold) do %>
      Sign in with Discord
    <% end %>
  </div>
</div>
