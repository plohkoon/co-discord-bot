<% content_for :title, "Dashboard · co-bot" %>

<%= render Ui::PageHeaderComponent.new(
      title: "Your servers",
      subtitle: "Servers where co-bot is installed and you have Manage Server.") %>

<% if @guilds.empty? && @member_guilds.empty? && @removed_guilds.empty? && @installable.empty? %>
  <%= render Ui::EmptyStateComponent.new do %>
    No servers yet. Join a Discord server where co-bot is installed, or install
    it on a server where you have <span class="text-foreground">Manage Server</span>.
  <% end %>
<% elsif @guilds.any? %>
  <div class="grid gap-3 sm:grid-cols-2">
    <% @guilds.each do |guild| %>
      <%= link_to guild_path(guild.id),
            class: "flex items-center gap-3 rounded-xl border border-border bg-card hover:bg-secondary/40 p-4 transition" do %>
        <%= render Ui::AvatarComponent.new(name: guild.name, size: :md) %>
        <div class="min-w-0">
          <div class="font-medium text-foreground truncate"><%= guild.name %></div>
          <div class="text-xs text-muted-foreground">Manage teams &amp; applications →</div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>

<% if @member_guilds.any? %>
  <div class="mt-8">
    <div class="text-sm font-medium text-foreground">Servers you're in</div>
    <p class="text-xs text-muted-foreground mt-1">
      Servers with co-bot where you're a member. Team leads can open their own teams.
    </p>
    <div class="grid gap-3 sm:grid-cols-2 mt-3">
      <% @member_guilds.each do |guild| %>
        <%= link_to guild_path(guild.id),
              class: "flex items-center gap-3 rounded-xl border border-border bg-card hover:bg-secondary/40 p-4 transition" do %>
          <%= render Ui::AvatarComponent.new(name: guild.name, size: :md) %>
          <div class="min-w-0">
            <div class="font-medium text-foreground truncate"><%= guild.name %></div>
            <div class="text-xs text-muted-foreground">View teams →</div>
          </div>
        <% end %>
      <% end %>
    </div>
  </div>
<% end %>

<% if @installable.any? %>
  <div class="mt-8"
       data-controller="install-poll"
       data-install-poll-url-value="<%= install_status_path(ids: @installable.map { |g| g["id"] }) %>">
    <div class="text-sm font-medium text-foreground">Add co-bot to a server</div>
    <p class="text-xs text-muted-foreground mt-1">
      Servers where you have Manage Server. This page updates automatically once the bot joins.
    </p>
    <div class="grid gap-3 sm:grid-cols-2 mt-3">
      <% @installable.each do |guild| %>
        <div class="flex items-center gap-3 rounded-xl border border-border border-dashed bg-card/50 p-4">
          <%= render Ui::AvatarComponent.new(name: guild["name"], size: :md) %>
          <div class="min-w-0 flex-1">
            <div class="font-medium text-foreground truncate"><%= guild["name"] %></div>
          </div>
          <%= link_to "Add co-bot", discord_install_url(guild_id: guild["id"]),
                target: "_blank", rel: "noopener",
                class: Ui::ButtonComponent.classes(variant: :gold, size: :sm) %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if @removed_guilds.any? %>
  <div class="mt-8">
    <div class="text-sm font-medium text-foreground">co-bot was removed from these servers</div>
    <p class="text-xs text-muted-foreground mt-1">
      Your teams and applications are kept — re-invite the bot to pick up where you left off.
    </p>
    <div class="grid gap-3 sm:grid-cols-2 mt-3">
      <% @removed_guilds.each do |guild| %>
        <div class="flex items-center gap-3 rounded-xl border border-border bg-card/50 p-4">
          <%= render Ui::AvatarComponent.new(name: guild.name, size: :md) %>
          <div class="min-w-0 flex-1">
            <div class="font-medium text-muted-foreground truncate"><%= guild.name %></div>
          </div>
          <%= link_to "Re-invite", discord_install_url(guild_id: guild.id),
                target: "_blank", rel: "noopener",
                class: Ui::ButtonComponent.classes(variant: :outline, size: :sm) %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>
