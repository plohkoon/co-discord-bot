<% content_for :title, "Dashboard · co-bot" %>

<h1 class="text-xl font-semibold text-slate-100 mb-1">Your servers</h1>
<p class="text-slate-400 text-sm mb-6">Servers where co-bot is installed and you have Manage Server.</p>

<% if @guilds.empty? %>
  <div class="rounded-xl border border-slate-800 bg-slate-900/40 p-8 text-center text-slate-400">
    No manageable servers yet. Make sure co-bot is in your server and you have the
    <span class="text-slate-200">Manage Server</span> permission.
  </div>
<% else %>
  <div class="grid gap-3 sm:grid-cols-2">
    <% @guilds.each do |guild| %>
      <%= link_to guild_path(guild["id"]),
            class: "flex items-center gap-3 rounded-xl border border-slate-800 bg-slate-900/40 hover:bg-slate-900 p-4 transition" do %>
        <div class="w-10 h-10 rounded-full bg-slate-700 flex items-center justify-center text-slate-300 font-semibold shrink-0">
          <%= guild["name"].to_s.first(1).upcase %>
        </div>
        <div class="min-w-0">
          <div class="font-medium text-slate-100 truncate"><%= guild["name"] %></div>
          <div class="text-xs text-slate-500">Manage teams &amp; applications →</div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
