<% content_for :title, "Application · #{@guild.name}" %>

<%= link_to "← Applications", guild_applications_path(@guild), class: "text-sm text-slate-500 hover:text-slate-300" %>

<div class="flex items-center justify-between mt-1 mb-1">
  <h1 class="text-xl font-semibold text-slate-100">
    <%= @application.discord_username.presence || @application.discord_user_id %>
  </h1>
  <%= render "team_applications/status_badge", status: @application.status %>
</div>
<p class="text-sm text-slate-400 mb-6">
  Applied to <span class="text-slate-200"><%= @application.team.name %></span> ·
  <%= @application.created_at.strftime("%b %-d, %Y at %H:%M") %>
  <% if @application.manual? %><span class="ml-1 text-slate-500">(role granted manually)</span><% end %>
</p>

<div class="grid lg:grid-cols-3 gap-8">
  <div class="lg:col-span-2 space-y-4">
    <% if @application.application_answers.any? %>
      <% @application.application_answers.each do |answer| %>
        <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
          <div class="text-xs text-slate-500 mb-1"><%= answer.question_label %></div>
          <div class="text-slate-200 whitespace-pre-wrap"><%= answer.answer.presence || "—" %></div>
        </div>
      <% end %>
    <% else %>
      <p class="text-slate-500 text-sm">No answers — this record came from a manual role grant.</p>
    <% end %>
  </div>

  <aside class="space-y-4">
    <% if @membership %>
      <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
        <div class="text-xs text-slate-500 uppercase tracking-wide mb-2">Membership</div>
        <%= render "team_applications/status_badge", status: @membership.status %>
        <% if @membership.joined_at %>
          <div class="text-xs text-slate-500 mt-2">Joined <%= @membership.joined_at.strftime("%b %-d, %Y") %></div>
        <% end %>
      </div>

      <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
        <div class="text-xs text-slate-500 uppercase tracking-wide mb-3">Notes <span class="text-slate-600">· officers only</span></div>

        <div class="space-y-3 mb-3">
          <% @membership.membership_notes.each do |note| %>
            <div class="text-sm">
              <div class="text-slate-200 whitespace-pre-wrap"><%= note.body %></div>
              <div class="text-xs text-slate-500 mt-0.5 flex items-center justify-between">
                <span><%= note.author_username.presence || note.author_discord_id %> · <%= note.created_at.strftime("%b %-d") %></span>
                <%= button_to "×", guild_membership_note_path(@guild, @membership, note), method: :delete,
                      class: "text-slate-600 hover:text-red-400 leading-none",
                      form: { data: { turbo_confirm: "Delete note?" } } %>
              </div>
            </div>
          <% end %>
          <% if @membership.membership_notes.empty? %>
            <p class="text-xs text-slate-500">No notes yet.</p>
          <% end %>
        </div>

        <%= form_with url: guild_membership_notes_path(@guild, @membership), scope: :membership_note do |f| %>
          <%= f.text_area :body, rows: 2, placeholder: "Add a note…",
                class: "w-full rounded-md bg-slate-800 border border-slate-700 px-3 py-1.5 text-sm text-slate-100 placeholder-slate-500 focus:outline-none focus:border-[#5865F2]" %>
          <div class="text-right mt-1">
            <%= f.submit "Add note", class: "text-xs rounded-md bg-[#5865F2] hover:bg-[#4752c4] px-3 py-1.5 font-medium text-white cursor-pointer" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </aside>
</div>
