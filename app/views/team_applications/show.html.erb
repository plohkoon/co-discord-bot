<% content_for :title, "Application · #{@guild.name}" %>

<%= link_to "← Applications", guild_applications_path(@guild), class: "text-sm text-slate-500 hover:text-slate-300" %>

<div class="flex items-center justify-between mt-1 mb-1">
  <h1 class="text-xl font-semibold text-slate-100">
    <%= @application.discord_username.presence || @application.discord_user_id %>
  </h1>
  <%= render "team_applications/status_badge", status: @application.status %>
</div>
<p class="text-sm text-slate-400 mb-6">
  Applied to <span class="text-slate-200"><%= @application.team.name %></span> ·
  <%= @application.created_at.strftime("%b %-d, %Y at %H:%M") %>
</p>

<div class="space-y-4">
  <% @application.application_answers.each do |answer| %>
    <div class="rounded-lg border border-slate-800 bg-slate-900/40 p-4">
      <div class="text-xs text-slate-500 mb-1"><%= answer.question_label %></div>
      <div class="text-slate-200 whitespace-pre-wrap"><%= answer.answer.presence || "—" %></div>
    </div>
  <% end %>
</div>
