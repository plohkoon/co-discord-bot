<% content_for :title, "Applications · #{@guild.name}" %>

<%= link_to "← #{@guild.name}", guild_path(@guild), class: "text-sm text-slate-500 hover:text-slate-300" %>
<h1 class="text-xl font-semibold text-slate-100 mt-1 mb-6">Applications</h1>

<% if @applications.empty? %>
  <p class="text-slate-500">No applications yet.</p>
<% else %>
  <div class="space-y-2">
    <% @applications.each do |application| %>
      <%= link_to guild_application_path(@guild, application),
            class: "flex items-center justify-between rounded-lg border border-slate-800 bg-slate-900/40 hover:bg-slate-900 px-4 py-3 transition" do %>
        <div>
          <div class="text-sm text-slate-200"><%= application.discord_username.presence || application.discord_user_id %></div>
          <div class="text-xs text-slate-500"><%= application.team.name %> · <%= time_ago_in_words(application.created_at) %> ago</div>
        </div>
        <%= render "team_applications/status_badge", status: application.status %>
      <% end %>
    <% end %>
  </div>
<% end %>
