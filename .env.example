# Copy to `.env` and fill in. `.env` is gitignored; this template is committed.

# --- Discord bot (gateway) ---
# Developer Portal > your app > Bot > Reset Token
# ALSO enable "Server Members Intent" on the Bot page — co-bot uses it to
# auto-sync team memberships when roles are granted/removed manually.
# The web app also uses this token (REST only) for the per-guild permission
# health check on the dashboard.
DISCORD_BOT_TOKEN=

# --- Discord OAuth2 (web login) ---
# Developer Portal > your app > OAuth2. Add redirect:
#   http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Local development ---
# Use a SEPARATE Discord application for development (e.g. "co-bot dev"): a bot
# token shared with production would deliver every gateway event to both
# processes, and each would fight to answer interactions and sync commands.
# Production credentials live in Fly secrets, not in a .env file.

# Run the gateway bot in-process with `bin/rails server` (production style).
# Leave blank in development and run the bot via `bin/dev` (Procfile.dev) instead.
RUN_DISCORD_BOT=
