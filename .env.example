# Copy to `.env` and fill in. `.env` is gitignored; this template is committed.

# --- Discord bot (gateway) ---
# Developer Portal > your app > Bot > Reset Token
DISCORD_BOT_TOKEN=

# --- Discord OAuth2 (web login) ---
# Developer Portal > your app > OAuth2. Add redirect:
#   http://localhost:3000/auth/discord/callback
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# --- Local development ---
# Your test server's ID. Slash commands register instantly to this one guild in
# development (global registration can take up to an hour to propagate).
# Enable Developer Mode in Discord, then right-click the server > Copy Server ID.
DISCORD_TEST_GUILD_ID=

# Base URL used to build the OAuth redirect. Defaults to http://localhost:3000.
APP_HOST=http://localhost:3000

# Run the gateway bot in-process with `bin/rails server` (production style).
# Leave blank in development and run the bot via `bin/dev` (Procfile.dev) instead.
RUN_DISCORD_BOT=
